{
  "name": "hyperclip",
  "version": "0.1.0",
  "description": "Official Node SDK for the Hyperclip API — create, poll, and manage flow runs.",
  "license": "MIT",
  "homepage": "https://hyperclip.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperclip/hyperclip-sdks.git",
    "directory": "node"
  },
  "bugs": "https://github.com/hyperclip/hyperclip-sdks/issues",
  "keywords": [
    "hyperclip",
    "video",
    "ai-video",
    "sdk",
    "api"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
